# Server
PORT=8080
APP_ENV=development

# JWT (Login / Auth)
# Caminho para o arquivo .pem da chave privada RSA 4096 bits. Gerar com: openssl genrsa -out private.pem 4096
JWT_PRIVATE_KEY_PATH=/path/to/private.pem
JWT_ISSUER=wisa-crm-service
JWT_EXPIRATION_MINUTES=15
JWT_KEY_ID=key-2026-v1
# Domínio base para compor aud do JWT: aud = tenant_slug + "." + JWT_AUD_BASE_DOMAIN (ex: cliente1.app.wisa-crm.com)
JWT_AUD_BASE_DOMAIN=app.wisa-crm.com

# Redis (authorization codes)
# Formato: redis://host:port/db ou redis://:password@host:port/db
REDIS_URL=redis://localhost:6379/0

# Database
# Formato: postgres://user:password@host:port/database?sslmode=disable
# Em produção use sslmode=require ou verify-full (ADR-003)
# Para usar o schema wisa_crm_db como padrão, inclua: options=-c%20search_path=wisa_crm_db
# Exemplo completo: postgres://wisa_crm:wisa_crm_secret@localhost:5432/wisa_crm_db?sslmode=disable&options=-c%20search_path=wisa_crm_db
DATABASE_URL=postgres://wisa_crm:wisa_crm_secret@localhost:5432/wisa_crm_db?sslmode=disable
