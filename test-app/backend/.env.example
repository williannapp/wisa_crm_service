# Auth server (wisa-crm-service)
AUTH_SERVER_URL=https://auth.wisa.labs.com.br

# Tenant and product slugs for test
TENANT_SLUG=cliente1
PRODUCT_SLUG=gestao-pocket

# Application URL (base for callback). Auth redirects to {APP_URL}/{product_slug}/callback
APP_URL=http://localhost:8081

# When frontend runs separately (e.g. ng serve :4201), set this to redirect after login
# FRONTEND_URL=http://localhost:4201

# JWT validation: must match claims emitted by auth server
# JWT_ISSUER: default = AUTH_SERVER_URL
# JWT_AUDIENCE: default = host from APP_URL (e.g. localhost:8081). Must match aud claim.
# JWT_ISSUER=wisa-crm-service
# JWT_AUDIENCE=localhost:8081

# Server port
PORT=8081
